  "techPreferences": {
    "language": "TypeScript across the entire project.",
    "frontend": "React with Next.js App Router for pages, layouts, components, and client/server rendering where appropriate.",
    "backend": "Next.js for backend capabilities using API routes or server actions, combined with Supabase Auth, PostgreSQL, and Supabase Storage.",
    "stateManagement": "Use a clean approach suitable for cart, auth, wishlist, and product browsing state.",
    "imageHandling": "Product and banner images should be stored in Supabase Storage.",
    "recommendedStructure": {
      "appRouter": true,
      "styling": "Use a scalable styling approach suitable for a premium UI.",
      "apiLayer": [
        "Next.js route handlers for protected admin operations if needed",
        "Supabase client on the frontend and server-side Supabase helpers or service-role usage only where appropriate"
      ]
    }
  },
  "claudeInstructions": {
    "goal": "Generate a complete grocery application based on this JSON.",
    "mustHave": [
      "TypeScript across the full codebase",
      "React frontend built with Next.js",
      "One gorgeous landing page",
      "One gorgeous responsive navbar",
      "Customer and single-admin roles",
      "Supabase Auth",
      "Supabase PostgreSQL database integration",
      "Admin-only dashboard and management pages",
      "Responsive UI for desktop and mobile",
      "Premium visual design rather than generic templates"
    ],
    "importantConstraints": [
      "Use TypeScript for all components, utilities, Supabase code, and backend logic.",
      "Use Next.js as the main framework for both frontend rendering and backend endpoints.",
      "There must be exactly one admin account.",
      "Customers can sign up normally, but admin cannot sign up publicly.",
      "Use Supabase with a SQL schema matching the tables and fields defined above.",
      "Preserve the premium landing page and navbar design quality."
    ]
  }
}
